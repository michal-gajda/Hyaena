{
  "AllowedHosts": "*",
  "OpenTelemetry": {
    "Service": {
      "Name": "hyaena",
      "Namespace": "poc",
      "Version": "1.0.0"
    }
  },
  "HealthChecks": {
    "ReverseProxy": {
      "ExcludedClusterIds": [ "otlp-collector" ]
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5080"
      }
    }
  },
  "ReverseProxy": {
    "Routes": {
      "otlp-route": {
        "ClusterId": "otlp-collector",
        "Match": {
          "Path": "/otlp/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/otlp"
          }
        ]
      },
      "iacula": {
        "ClusterId": "iacula-clusters",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      },
      "iacula-weather": {
        "ClusterId": "iacula-clusters",
        "Match": {
          "Path": "/WeatherForecast"
        }
      }
    },
    "Clusters": {
      "otlp-collector": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:4318"
          }
        }
      },
      "iacula-clusters": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:05",
            "Timeout": "00:00:02",
            "Policy": "ConsecutiveFailures",
            "Path": "/healthz"
          },
          "Passive": {
            "Enabled": true,
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:00:30"
          }
        },
        "Destinations": {
          "node-a": {
            "Address": "http://localhost:5081"
          },
          "node-b": {
            "Address": "http://localhost:5082"
          }
        }
      }
    }
  }
}
