{
  "AllowedHosts": "*",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5080"
      }
    }
  },
  "ReverseProxy": {
    "Routes": {
      "otlp-route": {
        "ClusterId": "otlp-collector",
        "Match": {
          "Path": "/otlp/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/otlp"
          }
        ]
      },
      "iacula": {
        "ClusterId": "iacula-clusters",
        "Match": {
          "Path": "/api/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api"
          }
        ]
      }
    },
    "Clusters": {
      "otlp-collector": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:4318"
          }
        }
      },
      "iacula-clusters": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:03",
            "Policy": "ConsecutiveFailures",
            "Path": "/healthz"
          },
          "Passive": {
            "Enabled": true,
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:00:30"
          }
        },
        "Metadata": {
          "TransportFailureRateHealthPolicy.RateLimit": "0.5"
        },
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5081"
          },
          "secondary": {
            "Address": "http://localhost:5082"
          }
        }
      }
    }
  }
}